    html {
      overflow-x: clip;
      max-width: 100%;
    }
    body {
      overflow-x: clip;
      max-width: 100%;
    }

    /* === SAFETY: kill any remaining 100vw from WP core or plugins === */
    .alignfull,
    .wp-block-cover.alignfull,
    .wp-block-group.alignfull {
      max-width: 100% !important;
      overflow-x: clip;
    }

    /* === FIX: sc-divider uses 100vw which causes overflow === */
    .sc-divider {
      width: 100% !important;
      max-width: 100% !important;
      margin-inline: 0 !important;
    }

    /* === TABLES: scrollable on mobile === */
    @media (max-width: 640px) {
      .wp-block-table {
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch;
        display: block !important;
        max-width: 100% !important;
      }
      .wp-block-table table {
        min-width: 480px;
      }
      figure.wp-block-table {
        overflow-x: auto !important;
        margin-inline: 0 !important;
      }
    }

    /* === BLOG POSTS: containment === */
    .sc-blog-post {
      max-width: 100% !important;
      overflow-x: hidden;
    }
    .sc-blog-post .wp-block-table {
      margin-inline: 0 !important;
    }

    /* === POST CONTENT: overflow guard === */
    .wp-block-post-content {
      overflow-x: hidden;
      max-width: 100%;
    }
    .wp-block-post-content > *:not(p):not(ul):not(ol):not(.wp-block-list):not(h1):not(h2):not(h3):not(h4):not(.wp-block-heading) {
      max-width: 100% !important;
    }

    /* === CONSTRAINED LAYOUTS: center properly === */
    .is-layout-constrained {
      margin-inline: auto !important;
    }

    /* === HEADER: tighten at <=414px === */
    @media (max-width: 414px) {
      .sc-header-bar.has-global-padding {
        padding-inline: var(--wp--preset--spacing--20) !important;
      }
      .sc-header-main {
        padding-inline: var(--wp--preset--spacing--10) !important;
        gap: var(--wp--preset--spacing--10) !important;
      }
      .sc-header-actions {
        gap: var(--wp--preset--spacing--10) !important;
      }
      .sc-header-actions .wp-block-buttons {
        gap: var(--wp--preset--spacing--10) !important;
      }
      .sc-header-actions .wp-block-button__link {
        padding-inline: var(--wp--preset--spacing--20) !important;
        font-size: var(--wp--preset--font-size--x-small) !important;
      }
      .sc-header-logo .wp-block-site-logo {
        max-width: 90px !important;
      }
      .sc-header-logo .wp-block-site-logo img {
        max-height: 16px !important;
      }
      .sc-lang-toggle .sc-lang-option {
        font-size: var(--wp--preset--font-size--x-small) !important;
        padding: var(--wp--preset--spacing--10) !important;
      }
    }

    /* === BUTTONS: wrap on mobile === */
    @media (max-width: 640px) {
      .wp-block-buttons {
        flex-wrap: wrap !important;
      }
      .sc-btn--full-mobile .wp-block-button__link,
      .sc-btn-group .wp-block-button__link {
        width: 100% !important;
        text-align: center !important;
      }
    }

    /* === EMBEDS: constrain === */
    .wp-block-embed,
    iframe {
      max-width: 100% !important;
    }

    /* === COLUMNS: stack on mobile with proper centering === */
    @media (max-width: 640px) {
      .wp-block-columns {
        flex-direction: column !important;
        gap: var(--wp--preset--spacing--40) !important;
      }
      .wp-block-column {
        flex-basis: 100% !important;
        width: 100% !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
      }
      /* Cards/packs in stacked columns: fill parent, center content */
      .wp-block-column > .sc-card,
      .wp-block-column > .sc-pack,
      .wp-block-column > .wp-block-group.sc-card,
      .wp-block-column > .wp-block-group.sc-pack {
        width: 100% !important;
        margin-inline: auto !important;
      }
    }

    /* === PANEL: ensure inner content doesn't overflow === */
    .sc-panel {
      max-width: 100%;
      box-sizing: border-box;
    }
    .sc-panel > .wp-block-columns {
      width: 100%;
    }

    /* === IMAGES: prevent overflow === */
    img {
      max-width: 100%;
      height: auto;
    }

    /* === NAV OVERLAY: use 100% not 100vw === */
    .wp-block-navigation__responsive-container {
      width: 100% !important;
      max-width: 100% !important;
    }

    /* === TRAINER CARDS: consistent portrait images === */
    .sc-trainer-listing .sc-card > a > img {
      width: 100%;
      height: auto;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      object-position: center top;
      display: block;
    }

    /* === TRAINER TAGS: ensure gap between pills === */
    .sc-trainer-tags {
      display: flex !important;
      flex-wrap: wrap !important;
      gap: var(--wp--preset--spacing--20) !important;
    }
    .sc-trainer-tag {
      display: inline-block;
    }
    .sc-trainer-langs {
      display: flex;
      gap: var(--wp--preset--spacing--20);
    }
/* === TRAINER LISTING: responsive grid === */
    .sc-trainer-listing {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--wp--preset--spacing--50, 32px);
      margin-top: var(--wp--preset--spacing--50, 32px);
    }
    /* === TRAINER CARD: card styling === */
    .sc-trainer-listing .sc-card {
      background: var(--wp--preset--color--base, #F7F5F2);
      border-radius: var(--wp--custom--primitives--radius-xl, 1.5rem);
      border: 1px solid var(--wp--preset--color--border, #D3CCC4);
      overflow: hidden;
      box-shadow: var(--wp--custom--shadow--sm);
      transition: box-shadow 220ms cubic-bezier(0.22,1,0.36,1),
        transform 220ms cubic-bezier(0.22,1,0.36,1);
    }
    .sc-trainer-listing .sc-card:hover {
      box-shadow: var(--wp--custom--shadow--lg);
      transform: translateY(-0.25rem);
    }
    .sc-trainer-listing .sc-card .sc-card-body {
      padding: var(--wp--preset--spacing--40, 20px);
    }
    .sc-trainer-listing .sc-card h3 {
      margin-top: 0;
      margin-bottom: var(--wp--preset--spacing--20, 8px);
    }
    @media (max-width: 600px) {
      .sc-trainer-listing {
        grid-template-columns: 1fr;
        gap: var(--wp--preset--spacing--40, 20px);
      }
